# hook_relay 환경변수 예시
# 실값으로 채운 뒤 hook_relay.env 로 저장하고 chmod 600 (커밋 금지).
# 모든 설정값은 코드에 하드코딩하지 않고 이 파일로만 관리한다.

# --- 서버 바인드 ---
HOST=0.0.0.0
APP_PORT=20000
UI_PORT=20001

# --- 실행 인터프리터 (uvicorn 구동용; 비우면 python3) ---
UVICORN_PYTHON=

# --- 데이터 ---
CHANNELS_CSV=./channels.csv

# --- 관리자 토큰 (채널 추가/수정/삭제; 강한 랜덤 권장) ---
DATA_ADMIN_TOKEN=

# --- 웹(20001) 접근 암호 (HTTP Basic; 비우면 DATA_ADMIN_TOKEN 사용) ---
WEB_PASSWORD=

# --- 웹(20001) TLS/HTTPS (둘 다 채우면 web 역할만 HTTPS 서빙; api(20000)는 평문 유지) ---
# certbot/Let's Encrypt/ZeroSSL 산출 파일을 제자리에서 참조(이동·개명 금지). cert.pem 아닌 fullchain.pem 권장.
# SSL_CERTFILE=/app/hook_relay/ssl/<도메인>/fullchain.pem
# SSL_KEYFILE=/app/hook_relay/ssl/<도메인>/privkey.pem
SSL_CERTFILE=
SSL_KEYFILE=

# --- 발송 봇 토큰 (쓰는 앱만 채움) ---
SLACK_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=
DISCORD_BOT_TOKEN=

# --- 발송 API URL (선택 오버라이드; 비우면 공식 기본값) ---
# SLACK_API_URL=https://slack.com/api/chat.postMessage
# TELEGRAM_API_BASE=https://api.telegram.org
# DISCORD_API_BASE=https://discord.com/api/v10
